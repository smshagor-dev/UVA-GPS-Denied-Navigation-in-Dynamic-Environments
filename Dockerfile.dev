FROM golang:1.22-bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        clang \
        clang-format \
        clang-tidy \
        cmake \
        curl \
        git \
        libeigen3-dev \
        libopencv-dev \
        libopenmpi-dev \
        libpcl-dev \
        libspdlog-dev \
        ninja-build \
        openmpi-bin \
        pkg-config \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY requirements.txt /tmp/requirements.txt

RUN python3 - <<'PY'
from pathlib import Path

requirements = Path("/tmp/requirements.txt").read_text(encoding="utf-8")
requirements = requirements.replace("numpy>=2.5.1", "numpy>=2.4.6")
requirements = requirements.replace("opencv-python>=5.0.0.93", "opencv-python>=4.10.0.84")
Path("/tmp/requirements.container.txt").write_text(requirements, encoding="utf-8")
PY

RUN python3 -m pip install --break-system-packages --no-cache-dir -r /tmp/requirements.container.txt \
    && python3 -m pip install --break-system-packages --no-cache-dir jsonschema

CMD ["/bin/bash"]
