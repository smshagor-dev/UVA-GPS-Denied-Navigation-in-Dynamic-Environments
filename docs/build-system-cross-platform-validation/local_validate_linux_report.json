      ],
      "returncode": 0
    },
    {
      "title": "CMake build",
      "command": [
        "cmake",
        "--build",
        "--preset",
        "validation-linux-gcc"
      ],
      "returncode": 0
    },
    {
      "title": "CTest",
      "command": [
        "ctest",
        "--preset",
