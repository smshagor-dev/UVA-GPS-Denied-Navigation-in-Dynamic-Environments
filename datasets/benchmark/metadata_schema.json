{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark Dataset Metadata",
  "type": "object",
  "required": [
    "dataset_id",
    "version",
    "task",
    "format",
    "created_at",
    "license",
    "metrics"
  ],
  "properties": {
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
