# Drone identity
DRONE_NODE_ID=1

# Sensor 1: IMU
DRONE_ENABLE_IMU=true
DRONE_IMU_DEVICE=/dev/i2c-1
DRONE_IMU_ADDR=104

# Sensor 2: Camera
DRONE_ENABLE_CAMERA=true
DRONE_ESP32_IP=192.168.4.1
DRONE_CAMERA_STREAM_URL=

# Sensor 3: LiDAR
DRONE_ENABLE_LIDAR=true
DRONE_LIDAR_ENDPOINT=192.168.1.201:2368

# Sensor 4: Barometer
DRONE_ENABLE_BAROMETER=true

# Sensor 5: Motor Health
DRONE_ENABLE_MOTOR=true

# Sensor 6: Optical Flow
DRONE_ENABLE_OPTICAL_FLOW=true

# Sensor 7: Rangefinder
DRONE_ENABLE_RANGEFINDER=true

# Sensor 8: TDOA Ingestor
DRONE_ENABLE_TDOA_INGESTOR=true
DRONE_TDOA_SERIAL=COM5
DRONE_TDOA_UDP_PORT=0
DRONE_TDOA_CSV=

# Sensor 9: UWB Serial
DRONE_ENABLE_UWB_SERIAL=true

# Swarm networking
DRONE_SECURITY_PROFILE=lab
DRONE_REQUIRE_SIGNED_COMMANDS=false
# In mTLS mode, DRONE_OPERATOR_ID should match the client certificate common name.
DRONE_OPERATOR_ID=operator-console-1
DRONE_OPERATOR_ROLE=operator
DRONE_OPERATOR_SECRET=replace-with-a-strong-operator-secret
# Optional multi-operator registry for the Go control-plane:
# format: operator_id:role:secret;operator_id_2:role:secret
DRONE_OPERATOR_CREDENTIALS=
DRONE_COMMAND_TTL_SEC=90
DRONE_MAX_COMMAND_SKEW_SEC=30
DRONE_COMMAND_NONCE_RETENTION_SEC=300
DRONE_TLS_ENABLED=false
DRONE_TLS_CERT_FILE=
DRONE_TLS_KEY_FILE=
DRONE_TLS_CA_FILE=
DRONE_TLS_REQUIRE_CLIENT_CERT=false
DRONE_TLS_CLIENT_CERT_FILE=
DRONE_TLS_CLIENT_KEY_FILE=
DRONE_TLS_SKIP_VERIFY=false
DRONE_SWARM_GROUP=239.255.0.1
DRONE_SWARM_PORT=7400
DRONE_SWARM_ADDR=:8080
DRONE_SWARM_SECRET=replace-with-a-strong-shared-secret

# Runtime assets
DRONE_YOLO_ENGINE=models/yolov8n.engine

# Dashboard / launcher
DRONE_GO_PORT=8080
DRONE_BACKEND_URL=http://127.0.0.1:8080
DRONE_ENABLE_BACKEND_TELEMETRY=false
DRONE_BACKEND_TELEMETRY_INTERVAL_MS=1000
DRONE_DASHBOARD_IDS=1,2,3,4,5
DRONE_DASHBOARD_POLL_HZ=20
