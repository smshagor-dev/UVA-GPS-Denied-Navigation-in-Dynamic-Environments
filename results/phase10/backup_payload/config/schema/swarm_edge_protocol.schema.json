{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/drone-swarm/config/swarm_edge_protocol.schema.json",
  "title": "Drone Swarm Edge Protocol Configuration",
  "type": "object",
  "required": ["serialization", "auth"],
  "properties": {
    "profile_name": { "type": "string", "minLength": 1 },
    "validated_state": { "type": "string", "minLength": 1 },
    "mesh_topology_mode": { "type": "string", "minLength": 1 },
    "serialization": {
      "type": "object",
      "required": ["serialization_mode"],
      "properties": {
        "serialization_mode": { "type": "string", "enum": ["json", "cbor", "protobuf_placeholder"] },
        "supported_modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "json_runtime_policy": { "type": "string" },
        "binary_transport_required_for_safety_critical_loops": { "type": "boolean" },
        "schema_version": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "auth": {
      "type": "object",
      "required": ["mode", "shared_secret_env"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "allow_unsigned_in_simulation": { "type": "boolean" },
        "allow_unsigned_in_bench": { "type": "boolean" },
        "trust_epoch": { "type": "integer", "minimum": 0 },
        "max_clock_skew_ms": { "type": "integer", "minimum": 0 },
        "shared_secret_env": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

