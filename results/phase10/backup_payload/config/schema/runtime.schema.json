{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/drone-swarm/config/runtime.schema.json",
  "title": "Drone Swarm Runtime Configuration",
  "type": "object",
  "required": ["version"],
  "properties": {
    "system_name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "dataset_type": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "coordinate_frame": { "type": "string", "minLength": 1 },
    "runtime_modes_supported": {
      "type": "array",
      "items": { "type": "string", "enum": ["simulation", "bench", "production", "edge_swarm"] },
      "minItems": 1
    },
    "runtime_mode": { "type": "string", "enum": ["simulation", "bench", "production", "edge_swarm"] },
    "anchor_config_path": { "type": "string", "minLength": 1 },
    "lidar_config_path": { "type": "string", "minLength": 1 },
    "detector_labels_path": { "type": "string", "minLength": 1 },
    "global_configuration": {
      "type": "object",
      "required": ["runtime_mode"],
      "properties": {
        "runtime_mode": { "type": "string", "enum": ["simulation", "bench", "production", "edge_swarm"] },
        "anchor_config_path": { "type": "string", "minLength": 1 },
        "lidar_config_path": { "type": "string", "minLength": 1 },
        "detector_labels_path": { "type": "string", "minLength": 1 },
        "telemetry_publish_rate_hz": { "type": "number", "minimum": 0 },
        "backend_mode": { "type": "string", "minLength": 1 },
        "safety_manager_enabled": { "type": "boolean" },
        "simulation_fallback_enabled": { "type": "boolean" },
        "pre_arm_required": { "type": "boolean" },
        "bench_validation_required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "runtime_sessions": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "anyOf": [
    { "required": ["global_configuration"] },
    { "required": ["runtime_mode"] }
  ],
  "additionalProperties": true
}

