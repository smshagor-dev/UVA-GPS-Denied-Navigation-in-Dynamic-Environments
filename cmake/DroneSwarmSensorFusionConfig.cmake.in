@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(NOT WIN32 AND NOT CMAKE_C_COMPILER_LOADED)
    include(CheckLanguage)
    check_language(C)
    if(CMAKE_C_COMPILER)
        enable_language(C)
    endif()
endif()

find_dependency(Threads)
find_dependency(Eigen3)
if(NOT WIN32)
    find_dependency(MPI COMPONENTS C)
endif()
find_dependency(OpenCV 4.5 COMPONENTS core imgproc highgui calib3d features2d video dnn)
find_dependency(PCL 1.12 COMPONENTS common io filters segmentation kdtree search)
find_dependency(spdlog CONFIG)
if(NOT WIN32)
    find_dependency(OpenSSL COMPONENTS Crypto)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/DroneSwarmSensorFusionTargets.cmake")
